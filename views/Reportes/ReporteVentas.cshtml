@model IEnumerable<TallerElectronika.Models.Venta>

@{
    ViewData["Title"] = "Reporte de Ventas";
}

<div class="row mb-4">
    <div class="col-12">
        <h1><i class="bi bi-graph-up"></i> Reporte de Ventas</h1>
    </div>
</div>

<!-- Filtros -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" action="@Url.Action("ReporteVentas", "Reportes")" class="row g-3">
            <div class="col-12 col-md-4">
                <label for="fechaInicio" class="form-label">Fecha Inicio</label>
                <input type="date" name="fechaInicio" id="fechaInicio" class="form-control" value="@(ViewBag.FechaInicio?.ToString("yyyy-MM-dd") ?? "")" />
            </div>
            <div class="col-12 col-md-4">
                <label for="fechaFin" class="form-label">Fecha Fin</label>
                <input type="date" name="fechaFin" id="fechaFin" class="form-control" value="@(ViewBag.FechaFin?.ToString("yyyy-MM-dd") ?? "")" />
            </div>
            <div class="col-12 col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Filtrar
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Estadísticas -->
<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-value">@ViewBag.CantidadVentas</div>
            <div class="stat-label">Total de Ventas</div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-value">@ViewBag.TotalVentas</div>
            <div class="stat-label">Monto Total</div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-value">@(ViewBag.CantidadVentas > 0 ? (ViewBag.TotalVentas / ViewBag.CantidadVentas).ToString("C") : "$0.00")</div>
            <div class="stat-label">Promedio por Venta</div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <form method="post" action="@Url.Action("GenerarPDFVentas", "Reportes")" style="display: inline;">
            <input type="hidden" name="fechaInicio" value="@(ViewBag.FechaInicio?.ToString("yyyy-MM-dd") ?? "")" />
            <input type="hidden" name="fechaFin" value="@(ViewBag.FechaFin?.ToString("yyyy-MM-dd") ?? "")" />
            <button type="submit" class="btn btn-danger w-100" style="height: 100%;">
                <i class="bi bi-file-pdf"></i> Descargar PDF
            </button>
        </form>
    </div>
</div>

<!-- Tabla de Ventas -->
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>ID Venta</th>
                    <th class="d-none d-md-table-cell">Cliente</th>
                    <th class="d-none d-lg-table-cell">Fecha</th>
                    <th class="text-end">Subtotal</th>
                    <th class="text-end">IVA</th>
                    <th class="text-end">Total</th>
                    <th class="d-none d-lg-table-cell">Estado</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count() > 0)
                {
                    @foreach (var venta in Model)
                    {
                        <tr>
                            <td><strong>#@venta.VentaId</strong></td>
                            <td class="d-none d-md-table-cell">@venta.Cliente?.Nombre @venta.Cliente?.Apellido</td>
                            <td class="d-none d-lg-table-cell">@venta.FechaVenta.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end">@venta.SubTotal.ToString("C")</td>
                            <td class="text-end">@venta.Impuesto.ToString("C")</td>
                            <td class="text-end"><strong>@venta.Total.ToString("C")</strong></td>
                            <td class="d-none d-lg-table-cell">
                                @{
                                    string badgeClass = venta.Estado switch
                                    {
                                        "Completada" => "bg-success",
                                        "Cancelada" => "bg-danger",
                                        _ => "bg-warning"
                                    };
                                }
                                <span class="badge @badgeClass">@venta.Estado</span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.Count() == 0)
{
    <div class="alert alert-info mt-3">
        <i class="bi bi-info-circle"></i> No hay ventas para mostrar en el período seleccionado.
    </div>
}

<!-- Resumen -->
@if (Model.Count() > 0)
{
    <div class="card mt-4">
        <div class="card-body">
            <h5 class="card-title">Resumen</h5>
            <div class="row">
                <div class="col-12 col-md-6">
                    <p><strong>Total Subtotal:</strong> <span class="text-end">@Model.Sum(v => v.SubTotal).ToString("C")</span></p>
                    <p><strong>Total IVA:</strong> <span class="text-end">@Model.Sum(v => v.Impuesto).ToString("C")</span></p>
                </div>
                <div class="col-12 col-md-6">
                    <p><strong style="font-size: 18px;">TOTAL GENERAL:</strong> <span class="text-primary" style="font-size: 18px; font-weight: bold;">@Model.Sum(v => v.Total).ToString("C")</span></p>
                </div>
            </div>
        </div>
    </div>
}

<div class="mt-3">
    <a href="@Url.Action("Index", "Reportes")" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>