@model IEnumerable<TallerElectronika.Models.Producto>

@{
    ViewData["Title"] = "Inventario";
}

<div class="row mb-4">
    <div class="col-12 col-sm-6">
        <h1 class="mb-0"><i class="bi bi-box"></i> Inventario</h1>
    </div>
    <div class="col-12 col-sm-6 text-end">
        <a href="@Url.Action("Create", "Inventario")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nuevo Producto
        </a>
    </div>
</div>

<!-- Tabla Responsiva -->
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th class="d-none d-lg-table-cell">Categoría</th>
                    <th class="text-end">Precio</th>
                    <th class="text-end">Stock</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var producto in Model)
                {
                    <tr>
                        <td><strong>@producto.CodigoProducto</strong></td>
                        <td>@producto.Nombre</td>
                        <td class="d-none d-lg-table-cell">@producto.Categoria</td>
                        <td class="text-end">@producto.PrecioUnitario.ToString("C")</td>
                        <td class="text-end">
                            @if (producto.Stock < producto.StockMinimo)
                            {
                                <span class="badge bg-danger">@producto.Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@producto.Stock</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <a href="@Url.Action("Details", "Inventario", new { id = producto.ProductoId })" class="btn btn-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="@Url.Action("Edit", "Inventario", new { id = producto.ProductoId })" class="btn btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="@Url.Action("Delete", "Inventario", new { id = producto.ProductoId })" style="display: inline;">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Estás seguro?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3">
        <i class="bi bi-info-circle"></i> No hay productos en el inventario.
    </div>
}