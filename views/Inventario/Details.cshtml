@model TallerElectronika.Models.Producto

@{
    ViewData["Title"] = "Detalles del Producto";
}

<div class="row mb-4">
    <div class="col-12">
        <h1><i class="bi bi-box"></i> @Model?.Nombre</h1>
    </div>
</div>

<div class="row">
    <div class="col-12 col-lg-8">
        <!-- Información del Producto -->
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-info-circle"></i> Información del Producto</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label text-muted">Código</label>
                        <p class="h6"><strong>@Model?.CodigoProducto</strong></p>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label text-muted">Categoría</label>
                        <p class="h6">@Model?.Categoria</p>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted">Descripción</label>
                    <p class="h6">@(string.IsNullOrEmpty(Model?.Descripcion) ? "---" : Model.Descripcion)</p>
                </div>

                <div class="row mb-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label text-muted">Precio Unitario</label>
                        <p class="h6" style="font-size: 1.3rem; color: var(--primary-color); font-weight: bold;">
                            @Model?.PrecioUnitario.ToString("C")
                        </p>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label text-muted">Fecha de Creación</label>
                        <p class="h6">@Model?.FechaCreacion.ToString("dd/MM/yyyy")</p>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12 col-md-6">
                        <label class="form-label text-muted">Estado</label>
                        <p class="h6">
                            @if (Model?.Activo == true)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Inventario -->
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-layers"></i> Información de Inventario</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label text-muted">Stock Actual</label>
                        <p class="h6" style="font-size: 1.3rem; font-weight: bold;">
                            @if (Model?.Stock < Model?.StockMinimo)
                            {
                                <span class="text-danger">@Model?.Stock <span class="badge bg-danger">BAJO</span></span>
                            }
                            else
                            {
                                <span class="text-success">@Model?.Stock <span class="badge bg-success">OK</span></span>
                            }
                        </p>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label text-muted">Stock Mínimo</label>
                        <p class="h6">@Model?.StockMinimo</p>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted">Valor Total del Stock</label>
                    <p class="h6" style="font-size: 1.3rem; color: var(--secondary-color); font-weight: bold;">
                        @{
                            decimal valorTotal = (Model?.Stock ?? 0) * (Model?.PrecioUnitario ?? 0);
                        }
                        @valorTotal.ToString("C")
                    </p>
                </div>
            </div>
        </div>

        <!-- Movimientos de Inventario -->
        @if (ViewBag.Movimientos != null && ((IEnumerable<dynamic>)ViewBag.Movimientos).Count() > 0)
        {
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-arrow-left-right"></i> Últimos Movimientos</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Tipo</th>
                                <th class="text-end">Cantidad</th>
                                <th class="d-none d-md-table-cell">Motivo</th>
                                <th class="d-none d-lg-table-cell">Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mov in ViewBag.Movimientos)
                            {
                                <tr>
                                    <td>
                                        @{
                                            string badgeClass = mov.TipoMovimiento == "Entrada" ? "bg-success" : "bg-danger";
                                        }
                                        <span class="badge @badgeClass">@mov.TipoMovimiento</span>
                                    </td>
                                    <td class="text-end"><strong>@mov.Cantidad</strong></td>
                                    <td class="d-none d-md-table-cell">@(string.IsNullOrEmpty(mov.Motivo) ? "---" : mov.Motivo)</td>
                                    <td class="d-none d-lg-table-cell">@mov.FechaMovimiento.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-4">
    <div class="d-grid gap-2 d-md-flex justify-content-md-start">
        <a href="@Url.Action("Edit", "Inventario", new { id = Model?.ProductoId })" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <a href="@Url.Action("Index", "Inventario", new { id = Model?.ProductoId })" class="btn btn-info">
            <i class="bi bi-arrow-left-right"></i> Movimientos
        </a>
        <form method="post" action="@Url.Action("Delete", "Inventario", new { id = Model?.ProductoId })" style="display: inline;">
            <button type="submit" class="btn btn-danger" onclick="return confirm('¿Estás seguro de que deseas eliminar este producto?')">
                <i class="bi bi-trash"></i> Eliminar
            </button>
        </form>
        <a href="@Url.Action("Index", "Inventario")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>