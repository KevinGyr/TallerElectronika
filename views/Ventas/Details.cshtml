@model TallerElectronika.Models.Venta

@{
    ViewData["Title"] = "Detalles de la Venta";
}

<div class="row mb-4">
    <div class="col-12">
        <h1><i class="bi bi-receipt"></i> Detalles de la Venta #@Model?.VentaId</h1>
    </div>
</div>

<div class="row">
    <div class="col-12 col-lg-10">
        <!-- Información General -->
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-info-circle"></i> Información General</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label text-muted">Cliente</label>
                        <p class="h6">@Model?.Cliente?.Nombre @Model?.Cliente?.Apellido</p>
                    </div>
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label text-muted">Fecha de Venta</label>
                        <p class="h6">@Model?.FechaVenta.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label class="form-label text-muted">Estado</label>
                        <p class="h6">
                            @{
                                string badgeClass = Model?.Estado switch
                                {
                                    "Completada" => "bg-success",
                                    "Cancelada" => "bg-danger",
                                    _ => "bg-warning"
                                };
                            }
                            <span class="badge @badgeClass">@Model?.Estado</span>
                        </p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model?.Observaciones))
                {
                    <div class="mb-3">
                        <label class="form-label text-muted">Observaciones</label>
                        <p class="h6">@Model?.Observaciones</p>
                    </div>
                }
            </div>
        </div>

        <!-- Productos de la Venta -->
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-box"></i> Productos (@Model?.VentaDetalles?.Count ?? 0)</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th class="text-end">Cantidad</th>
                            <th class="text-end">Precio Unit.</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.VentaDetalles != null && Model.VentaDetalles.Count > 0)
                        {
                            @foreach (var detalle in Model.VentaDetalles)
                            {
                                <tr>
                                    <td><strong>@detalle.Producto?.Nombre</strong></td>
                                    <td class="text-end">@detalle.Cantidad</td>
                                    <td class="text-end">@detalle.PrecioUnitario.ToString("C")</td>
                                    <td class="text-end"><strong>@detalle.Subtotal.ToString("C")</strong></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Resumen de la Venta -->
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-12 col-md-6 mb-2">
                        <div class="d-flex justify-content-between">
                            <strong>Subtotal:</strong>
                            <span>@Model?.SubTotal.ToString("C")</span>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 mb-2">
                        <div class="d-flex justify-content-between">
                            <strong>IVA (16%):</strong>
                            <span>@Model?.Impuesto.ToString("C")</span>
                        </div>
                    </div>
                    <div class="col-12 border-top pt-2">
                        <div class="d-flex justify-content-between" style="font-size: 1.2rem;">
                            <strong>Total:</strong>
                            <span class="text-primary" style="font-weight: bold;">@Model?.Total.ToString("C")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a href="@Url.Action("Index", "Ventas")" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>