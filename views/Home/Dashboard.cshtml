@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-12">
        <h1 class="mb-0"><i class="bi bi-speedometer2"></i> Dashboard</h1>
    </div>
</div>

<!-- Estadísticas -->
<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-value">@ViewBag.TotalClientes</div>
            <div class="stat-label">Total de Clientes</div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-value">@ViewBag.TotalProductos</div>
            <div class="stat-label">Total de Productos</div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-value">@ViewBag.TotalVentas</div>
            <div class="stat-label">Total de Ventas</div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-value">@ViewBag.VentasTotales.ToString("C")</div>
            <div class="stat-label">Ventas Totales</div>
        </div>
    </div>
</div>

<!-- Mensaje de Bienvenida -->
<div class="alert alert-info" role="alert">
    <i class="bi bi-info-circle"></i> Bienvenido al Sistema de Gestión de Taller Electrónika
</div>