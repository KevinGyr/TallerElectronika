@model TallerElectronika.Models.Cliente

@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div class="row mb-4">
    <div class="col-12">
        <h1><i class="bi bi-person"></i> Detalles del Cliente</h1>
    </div>
</div>

<div class="row">
    <div class="col-12 col-lg-8">
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0"><i class="bi bi-person-circle"></i> Información Personal</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label text-muted">Nombre</label>
                        <p class="h6">@Model?.Nombre</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label text-muted">Apellido</label>
                        <p class="h6">@Model?.Apellido</p>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted">Email</label>
                    <p class="h6">
                        <a href="mailto:@Model?.Email">@Model?.Email</a>
                    </p>
                </div>

                <div class="row mb-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label text-muted">Teléfono</label>
                        <p class="h6">@(string.IsNullOrEmpty(Model?.Telefono) ? "---" : Model.Telefono)</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label text-muted">Ciudad</label>
                        <p class="h6">@(string.IsNullOrEmpty(Model?.Ciudad) ? "---" : Model.Ciudad)</p>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted">Dirección</label>
                    <p class="h6">@(string.IsNullOrEmpty(Model?.Direccion) ? "---" : Model.Direccion)</p>
                </div>

                <div class="row">
                    <div class="col-12 col-md-6">
                        <label class="form-label text-muted">Fecha de Registro</label>
                        <p class="h6">@Model?.FechaRegistro.ToString("dd/MM/yyyy")</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label text-muted">Estado</label>
                        <p class="h6">
                            @if (Model?.Activo == true)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>

        @if (Model?.Ventas != null && Model.Ventas.Count > 0)
        {
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="bi bi-cart"></i> Historial de Compras</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID Venta</th>
                                <th class="d-none d-md-table-cell">Fecha</th>
                                <th class="text-end">Total</th>
                                <th class="d-none d-lg-table-cell">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var venta in Model.Ventas.OrderByDescending(v => v.FechaVenta))
                            {
                                <tr>
                                    <td><strong>#@venta.VentaId</strong></td>
                                    <td class="d-none d-md-table-cell">@venta.FechaVenta.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end">@venta.Total.ToString("C")</td>
                                    <td class="d-none d-lg-table-cell">
                                        @{
                                            string badgeClass = venta.Estado switch
                                            {
                                                "Completada" => "bg-success",
                                                "Cancelada" => "bg-danger",
                                                _ => "bg-warning"
                                            };
                                        }
                                        <span class="badge @badgeClass">@venta.Estado</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-light">
                    <strong>Total gastado:</strong> @Model.Ventas.Sum(v => v.Total).ToString("C")
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-4">
    <div class="d-grid gap-2 d-md-flex justify-content-md-start">
        <a href="@Url.Action("Edit", "Clientes", new { id = Model?.ClienteId })" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <form method="post" action="@Url.Action("Delete", "Clientes", new { id = Model?.ClienteId })" style="display: inline;">
            <button type="submit" class="btn btn-danger" onclick="return confirm('¿Estás seguro de que deseas eliminar este cliente?')">
                <i class="bi bi-trash"></i> Eliminar
            </button>
        </form>
        <a href="@Url.Action("Index", "Clientes")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>